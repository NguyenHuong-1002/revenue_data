meta {
  name: InterpretRetailReport
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/ai/interpretation
  body: json
  headers: {
    Authorization: Bearer {{adminToken}}
    Content-Type: application/json
  }
}

body:json {
  {
    "reportTitle": "Phân tích biểu đồ Doanh thu tháng này",
    "totalRevenue": 150000000,
    "revenueChangePercent": 12,
    "topProductName": "Áo sơ mi nam",
    "topProductCode": "SANTD-01",
    "topProductSoldQuantity": 400,
    "currentStock": 50,
    "avgWeightPerPieceKg": 0.3,
    "additionalContext": "Hãy phân tích dữ liệu trên và đề xuất hành động nhập hàng.",
    "language": "vi"
  }
}

tests {
  const response = res.getBody();

  expect(res.status).to.equal(200);
  expect(response).to.have.property('provider');
  expect(response.provider).to.equal('deepseek');
  expect(response).to.have.property('model');
  expect(response).to.have.property('content');
  expect(response.content).to.have.property('summaryBullets');
  expect(response.content).to.have.property('recommendation');
  expect(Array.isArray(response.content.summaryBullets)).to.be.true;
}

