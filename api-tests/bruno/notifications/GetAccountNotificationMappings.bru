meta {
  name: GetAccountNotificationMappings (Admin)
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/notifications/accounts/{{staffAccountId}}/mappings?page=1&limit=20
  body: none
  headers: {
    Authorization: Bearer {{adminToken}}
    Content-Type: application/json
  }
}

tests {
  const response = res.getBody();

  expect(res.status, 'get account notification mappings should return 200').to.equal(200);
  expect(response, 'mapping list should include data').to.have.property('data');
  expect(response, 'mapping list should include meta').to.have.property('meta');
  expect(response.meta, 'mapping list should include page').to.have.property('page', 1);
  expect(response.meta, 'mapping list should include limit').to.have.property('limit', 20);
  expect(response.meta, 'mapping list should include total').to.have.property('total');
  expect(response.meta, 'mapping list should include totalPages').to.have.property('totalPages');
  expect(Array.isArray(response.data), 'mapping list data should be an array').to.be.true;

  response.data.forEach(mapping => {
    expect(mapping, 'mapping should include account_id').to.have.property('account_id', bru.getEnvVar('staffAccountId'));
    expect(mapping, 'mapping should include notification_id').to.have.property('notification_id');
    expect(mapping, 'mapping should include title').to.have.property('title');
    expect(mapping, 'mapping should include content').to.have.property('content');
    expect(mapping, 'mapping should include type').to.have.property('type');
    expect(mapping, 'mapping should include is_read').to.have.property('is_read');
    expect(mapping, 'mapping should include read_at').to.have.property('read_at');
    expect(mapping, 'mapping should include is_deleted').to.have.property('is_deleted');
    expect(mapping, 'mapping should include deleted_at').to.have.property('deleted_at');
    expect(mapping, 'mapping should include created_at').to.have.property('created_at');
    expect(mapping, 'mapping should include updated_at').to.have.property('updated_at');
  });

  if (response.data.length > 0) {
    bru.setEnvVar('currentNotificationId', response.data[0].notification_id);
  }
}
