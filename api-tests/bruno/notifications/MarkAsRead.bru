meta {
  name: MarkAsRead
  type: http
  seq: 2
}

patch {
  url: {{baseUrl}}/notifications/{{currentNotificationId}}/read
  body: none
  headers: {
    Authorization: Bearer {{adminToken}}
    Content-Type: application/json
  }
}

tests {
  const response = res.getBody();

  expect(res.status).to.equal(200);
  expect(response).to.have.property('notification_id', bru.getEnvVar('currentNotificationId'));
  expect(response).to.have.property('read_at').that.is.not.null;
}
