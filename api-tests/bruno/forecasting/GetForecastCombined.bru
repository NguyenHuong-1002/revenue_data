meta {
  name: GetForecastCombined
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/forecast?horizon=3&alpha=0.3
  body: none
  headers: {
    Authorization: Bearer {{adminToken}}
    Content-Type: application/json
  }
}

tests {
  const response = res.getBody();

  expect(res.status).to.equal(200);
  expect(response).to.have.property('horizon');
  expect(response).to.have.property('alpha');
  expect(response).to.have.property('filters');
  expect(response).to.have.property('sales');
  expect(response).to.have.property('inventory');
  expect(response).to.have.property('warnings');
  expect(Array.isArray(response.warnings)).to.be.true;

  if (response.sales) {
    expect(response.sales).to.have.property('source');
    expect(response.sales).to.have.property('history');
    expect(response.sales).to.have.property('ema');
    expect(response.sales).to.have.property('linearRegression');
  }

  if (response.inventory) {
    expect(response.inventory).to.have.property('source');
    expect(response.inventory).to.have.property('history');
    expect(response.inventory).to.have.property('ema');
    expect(response.inventory).to.have.property('linearRegression');
  }
}

