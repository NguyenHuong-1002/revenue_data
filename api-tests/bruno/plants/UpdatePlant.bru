meta {
  name: UpdatePlant (Admin)
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/plants/{{currentPlantId}}
  body: json
  headers: {
    Authorization: Bearer {{adminToken}}
    Content-Type: application/json
  }
}

body:json {
  {
    "name_plant": "Nhà máy Thử Nghiệm (Đã cập nhật)",
    "phone": "0999999999"
  }
}

tests {
  const response = res.getBody();

  expect(res.status).to.equal(200);
  expect(response).to.have.property('name_plant', 'Nhà máy Thử Nghiệm (Đã cập nhật)');
  expect(response).to.have.property('phone', '0999999999');
}
