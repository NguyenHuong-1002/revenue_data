meta {
  name: GetMe
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/accounts/me
  body: none
  headers: {
    Authorization: Bearer {{adminToken}}
    Content-Type: application/json
  }
}

tests {
  const response = res.getBody();

  expect(res.status, 'get me should return 200').to.equal(200);
  expect(response, 'get me should include account_id').to.have.property('account_id');
  expect(response, 'get me should return admin username').to.have.property('username', bru.getEnvVar('adminUsername'));
  expect(response, 'get me should return role ADMIN').to.have.property('role', 'ADMIN');
  expect(response, 'get me should include fullname').to.have.property('fullname');
  expect(response, 'get me should include mail').to.have.property('mail');
  expect(response, 'get me should include avatarURL').to.have.property('avatarURL');
  expect(response, 'get me should include created_at').to.have.property('created_at');
  expect(response, 'get me should include updated_at').to.have.property('updated_at');
  expect(response, 'get me should not leak passwordHash').to.not.have.property('passwordHash');
}
