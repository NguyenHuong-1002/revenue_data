meta {
  name: GetUsersAll - Invalid Pagination
  type: http
  seq: 20
}

get {
  url: {{baseUrl}}/accounts?page=0&limit=10
  body: none
  headers: {
    Authorization: Bearer {{adminToken}}
    Content-Type: application/json
  }
}

tests {
  const response = res.getBody();
  const messageText = Array.isArray(response.message) ? response.message.join(' ') : String(response.message);

  expect(res.status).to.equal(400);
  expect(response).to.have.property('statusCode', 400);
  expect(messageText.toLowerCase()).to.include('page');
  expect(response).to.have.property('path', '/accounts?page=0&limit=10');
  expect(response).to.have.property('method', 'GET');
}
