meta {
  name: UploadAvatar
  type: http
  seq: 12
}

post {
  url: {{baseUrl}}/accounts/avatar
  body: multipart-form
  headers: {
    Authorization: Bearer {{adminToken}}
  }
}

body:multipart-form {
  file: @file(upload-avatar.jpg)
}

tests {
