meta {
  name: UploadAvatar
  type: http
  seq: 12
}

post {
  url: {{baseUrl}}/accounts/avatar
  body: multipart-form
  headers: {
    Authorization: Bearer {{adminToken}}
  }
}

body:multipart-form {
  file: @file(test-avatar.jpg)
}

tests {
  const response = res.getBody();

  expect(res.status).to.equal(200);
  expect(response).to.have.property('success', true);
  expect(response).to.have.property('message', 'Cập nhật ảnh đại diện thành công!');
  expect(response).to.have.property('avatarURL').that.is.a('string');
}
