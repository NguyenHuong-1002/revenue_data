meta {
  name: CreateAccount
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/accounts
  body: json
  headers: {
    Authorization: Bearer {{adminToken}}
    Content-Type: application/json
  }
}

body:json {
  {
    "fullname": "Nguyen Van B",
    "username": "created_staff_" + $randomUUID,
    "password": "Matkhau@123",
    "mail": "created_staff_" + $randomUUID + "@revenue.com",
    "role": "STAFF"
  }
}

tests {
  const response = res.getBody();

  expect(res.status, 'create account should return 201').to.equal(201);
  expect(response, 'created account should have account_id').to.have.property('account_id');
  expect(response, 'created account should have username').to.have.property('username');
  expect(response, 'created account should be STAFF').to.have.property('role', 'STAFF');
  expect(response, 'created account should keep fullname').to.have.property('fullname', 'Nguyen Van B');
  expect(response, 'created account should have mail').to.have.property('mail');
  expect(response, 'created account should default avatarURL to empty string').to.have.property('avatarURL', '');
  expect(response, 'created account should have created_at').to.have.property('created_at');
  expect(response, 'created account should have updated_at').to.have.property('updated_at');
  expect(response, 'created account should not leak passwordHash').to.not.have.property('passwordHash');

  bru.setEnvVar('currentTestUserId', response.account_id);
}
