meta {
  name: Login (Admin)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/accounts/login
  body: json
  headers: {
    Content-Type: application/json
  }
}

body:json {
  {
    "username": "{{adminUsername}}",
    "password": "{{adminPassword}}"
  }
}

tests {
  const response = res.getBody();

  expect(res.status, 'admin login should return 200').to.equal(200);
  expect(response, 'admin login should include success message').to.have.property('message', 'Success');
  expect(response, 'admin login should include accessToken').to.have.property('accessToken');
  expect(response, 'admin login should include tokenType').to.have.property('tokenType', 'Bearer');
  expect(response.accessToken, 'admin accessToken should be a non-empty string').to.be.a('string').and.not.empty;
  expect(response.account, 'admin login should include account_id').to.have.property('account_id');
  expect(response.account, 'admin login should return admin username').to.have.property('username', bru.getEnvVar('adminUsername'));
  expect(response.account, 'admin login should return role ADMIN').to.have.property('role', 'ADMIN');
  expect(response.account, 'admin login should include fullname').to.have.property('fullname');
  expect(response.account, 'admin login should include mail').to.have.property('mail');
  expect(response.account, 'admin login should include avatarURL').to.have.property('avatarURL');
  expect(response.account, 'admin login should include created_at').to.have.property('created_at');
  expect(response.account, 'admin login should include updated_at').to.have.property('updated_at');
  expect(response.account, 'admin login should not leak passwordHash').to.not.have.property('passwordHash');

  bru.setEnvVar('adminToken', response.accessToken);
}
