meta {
  name: Register - Duplicate Username
  type: http
  seq: 16
}

post {
  url: {{baseUrl}}/accounts/register
  body: json
  headers: {
    Content-Type: application/json
  }
}

body:json {
  {
    "fullname": "Duplicate Username User",
    "username": "{{adminUsername}}",
    "password": "Test@123",
    "mail": "duplicate_username_" + $randomUUID + "@revenue.com"
  }
}

tests {
  const response = res.getBody();

  expect(res.status).to.equal(409);
  expect(response).to.have.property('statusCode', 409);
  expect(response).to.have.property('message', 'Username da ton tai');
  expect(response).to.have.property('path', '/accounts/register');
  expect(response).to.have.property('method', 'POST');
}
