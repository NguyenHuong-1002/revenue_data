meta {
  name: GetAccountById - Not Found
  type: http
  seq: 19
}

get {
  url: {{baseUrl}}/accounts/00000000-0000-0000-0000-000000000000
  body: none
  headers: {
    Authorization: Bearer {{adminToken}}
    Content-Type: application/json
  }
}

tests {
  const response = res.getBody();

  expect(res.status).to.equal(404);
  expect(response).to.have.property('statusCode', 404);
  expect(response).to.have.property('message');
  expect(String(response.message)).to.include('not found');
  expect(response).to.have.property('path', '/accounts/00000000-0000-0000-0000-000000000000');
  expect(response).to.have.property('method', 'GET');
}
