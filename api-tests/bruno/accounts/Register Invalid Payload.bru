meta {
  name: Register - Invalid Payload
  type: http
  seq: 15
}

post {
  url: {{baseUrl}}/accounts/register
  body: json
  headers: {
    Content-Type: application/json
  }
}

body:json {
  {
    "fullname": "New User",
    "username": "register_invalid_" + $randomUUID,
    "password": "123",
    "mail": "invalid-email"
  }
}

tests {
  const response = res.getBody();
  const messageText = Array.isArray(response.message) ? response.message.join(' ') : String(response.message);

  expect(res.status).to.equal(400);
  expect(response).to.have.property('statusCode', 400);
  expect(messageText).to.include('Email khong dung dinh dang!');
  expect(messageText).to.include('Password phai co it nhat 6 ky tu!');
  expect(response).to.have.property('path', '/accounts/register');
  expect(response).to.have.property('method', 'POST');
}
