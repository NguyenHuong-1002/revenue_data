meta {
  name: CreateProduct
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/products
  body: json
  headers: {
    Authorization: Bearer {{adminToken}}
    Content-Type: application/json
  }
}

body:json {
  {
    "color": "Đen",
    "listing_price": 450000,
    "price_cost": 300000,
    "gender": "Nam",
    "detail_product_group": "Giày thể thao",
    "size": 42,
    "age_group": "24 đến <40 tuổi",
    "activity_group": "Thể thao",
    "lifestyle_group": "Sport"
  }
}

tests {
  const response = res.getBody();

  expect(res.status).to.equal(201);
  expect(response).to.have.property('product_id');
  expect(response).to.have.property('color', 'Đen');
  expect(response).to.have.property('listing_price', 450000);
  expect(response).to.have.property('price_cost', 300000);
  expect(response).to.have.property('gender', 'Nam');

  bru.setEnvVar('currentProductId', response.product_id);
}
