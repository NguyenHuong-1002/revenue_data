meta {
  name: DeleteProduct
  type: http
  seq: 5
}

delete {
  url: {{baseUrl}}/products/{{currentProductId}}
  body: none
  headers: {
    Authorization: Bearer {{adminToken}}
    Content-Type: application/json
  }
}

tests {
  expect(res.status).to.equal(200);

  const response = res.getBody();
  expect(response).to.be.true;
}
