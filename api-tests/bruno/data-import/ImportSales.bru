meta {
  name: Import Sales (Excel)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/import/sales
  body: multipart-form
  headers: {
    Authorization: Bearer {{adminToken}}
  }
}

body:multipart-form {
  file: @file(../../data/sales/2022-01-SaleReport.xlsx)
}

tests {
