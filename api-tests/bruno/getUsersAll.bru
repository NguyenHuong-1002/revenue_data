meta {
  name: Lấy danh sách tất cả tài khoản (getUsersAll)
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/accounts?page=1&limit=10
  body: none
  auth: inherit
}

query {
  page: 1
  limit: 10
}

tests {
  // 1. Kiểm tra mã trạng thái phản hồi phải là 200 OK
  test("Status code is 200 OK", function () {
      expect(res.status).to.equal(200);
  });
  
  // 2. Kiểm tra định dạng dữ liệu trả về là JSON
  test("Content-Type is application/json", function () {
      expect(res.headers['content-type']).to.include("application/json");
  });
  
  // 3. Kiểm tra tốc độ phản hồi phải dưới 500ms
  test("Response time is less than 500ms", function () {
      expect(res.responseTime).to.be.below(500);
  });
  
  // 4. Kiểm tra cấu trúc phân trang tổng quát
  test("Response has required 'data' and 'meta' properties", function () {
      expect(res.body).to.be.an("object");
      expect(res.body).to.have.property("data");
      expect(res.body).to.have.property("meta");
      expect(res.body.data).to.be.an("array");
      expect(res.body.meta).to.be.an("object");
  });
  
  // 5. Kiểm tra tính toàn vẹn của siêu dữ liệu phân trang
  test("Metadata has valid pagination properties", function () {
      const meta = res.body.meta;
      expect(meta).to.have.property("page");
      expect(meta).to.have.property("limit");
      expect(meta).to.have.property("total");
      expect(meta).to.have.property("totalPages");
      
      expect(meta.page).to.be.a("number");
      expect(meta.limit).to.be.a("number");
      expect(meta.total).to.be.a("number");
      expect(meta.totalPages).to.be.a("number");
  });
  
  // 6. Kiểm tra chi tiết cấu trúc dữ liệu của từng Account trong danh sách
  test("Each account in data array has correct fields and types", function () {
      const accounts = res.body.data;
      if (accounts.length > 0) {
          accounts.forEach(function (user) {
              expect(user).to.have.property("account_id").and.be.a("string");
              expect(user).to.have.property("fullname").and.be.a("string");
              expect(user).to.have.property("username").and.be.a("string");
              expect(user).to.have.property("mail").and.be.a("string");
              expect(user).to.have.property("role").and.be.a("string");
              expect(["ADMIN", "STAFF"]).to.include(user.role);
              
              // Email check
              const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
              expect(emailRegex.test(user.mail)).to.be.true;
          });
      }
  });
  
  // 7. KIỂM TRA BẢO MẬT: Không được để lộ password hash
  test("SECURITY CHECK: Response must not leak password_hash or password", function () {
      const accounts = res.body.data;
      if (accounts.length > 0) {
          accounts.forEach(function (user) {
              expect(user).to.not.have.property("password");
              expect(user).to.not.have.property("passwordHash");
              expect(user).to.not.have.property("password_hash");
          });
      }
  });
  
  // 8. Tự động lưu account_id của user đầu tiên làm biến môi trường trong Bruno để chain sang test getAccountById
  test("Save first user ID to environment variables", function () {
      if (res.body.data && res.body.data.length > 0) {
          const firstUserId = res.body.data[0].account_id;
          bru.setEnvVar("current_test_user_id", firstUserId);
          console.log("Saved current_test_user_id: " + firstUserId);
      }
  });
}
