meta {
  name: GetBranches
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/branches?page=1&limit=10
  body: none
  headers: {
    Authorization: Bearer {{adminToken}}
    Content-Type: application/json
  }
}

tests {
  const response = res.getBody();

  expect(res.status).to.equal(200);
  expect(response).to.have.property('data');
  expect(response).to.have.property('meta');
  expect(response.meta).to.have.property('page', 1);
  expect(response.meta).to.have.property('limit', 10);
  expect(Array.isArray(response.data)).to.be.true;
  
  if (response.data.length > 0) {
    bru.setEnvVar('currentBranchId', response.data[0].store_id);
  }
}
