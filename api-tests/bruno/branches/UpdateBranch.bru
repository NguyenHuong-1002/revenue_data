meta {
  name: UpdateBranch (Admin)
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/branches/{{currentBranchId}}
  body: json
  headers: {
    Authorization: Bearer {{adminToken}}
    Content-Type: application/json
  }
}

body:json {
  {
    "name": "Chi Nhánh Thử Nghiệm (Đã cập nhật)",
    "city": "Đà Nẵng"
  }
}

tests {
  const response = res.getBody();

  expect(res.status).to.equal(200);
  expect(response).to.have.property('name', 'Chi Nhánh Thử Nghiệm (Đã cập nhật)');
  expect(response).to.have.property('city', 'Đà Nẵng');
}
