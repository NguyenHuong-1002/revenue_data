{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "dev": "nest build --webpack --webpackPath webpack-hmr.config.js --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs}/**/*.ts\" --fix",
    "db:init": "npx ts-node scripts/init-db.ts",
    "db:setup": "npm run db:init && npm run data:all",
    "data:products": "npx ts-node --require tsconfig-paths/register scripts/import-data.ts products",
    "data:sales": "npx ts-node --require tsconfig-paths/register scripts/import-data.ts sales",
    "data:inventory": "npx ts-node --require tsconfig-paths/register scripts/import-data.ts inventory",
    "data:all": "npx ts-node --require tsconfig-paths/register scripts/import-data.ts all",
    "check-data": "npx ts-node scripts/check-data.ts",
    "migration:generate": "typeorm migration:generate -d src/config/data-source.ts src/migrations/%npm_config_name%",
    "migration:run": "typeorm migration:run -d src/config/data-source.ts",
    "migration:revert": "typeorm migration:revert -d src/config/data-source.ts",
    "migration:create": "typeorm migration:create src/migrations/%npm_config_name%"
  },
  "scriptsDescription": {
    "build": "Biên dịch TypeScript sang JavaScript",
    "format": "Định dạng code bằng Prettier",
    "start": "Chạy server",
    "dev": "Chạy ở chế độ phát triển (HMR)",
    "start:prod": "Chạy server ở chế độ production",
    "n": "Kiểm tra lỗi ESLint",
    "db:init": "Khởi tạo database & tables từ database/init.sql",
    "db:setup": "Khởi tạo DB + import toàn bộ dữ liệu (1 lệnh duy nhất)",
    "data:products": "Import dữ liệu sản phẩm từ Excel",
    "data:sales": "Import dữ liệu bán hàng từ Excel",
    "data:inventory": "Import dữ liệu tồn kho từ Excel",
    "data:all": "Import toàn bộ dữ liệu (products + sales + inventory)"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.3",
    "@nestjs/typeorm": "^11.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "exceljs": "^3.4.0",
    "mysql2": "^3.22.3",
    "pdfkit": "^0.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "typeorm": "^1.0.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.0.0",
    "@types/pdfkit": "^0.17.6",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "prettier": "^3.4.2",
    "run-script-webpack-plugin": "^0.2.3",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "webpack": "^5.106.2",
    "webpack-node-externals": "^3.0.0"
  }
}